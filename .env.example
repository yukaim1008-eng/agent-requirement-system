# DeepSeek API Key (required) - get from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-api-key-here

# Tavily Search API Key (optional) - for real-time competitor research
# Leave empty to auto-fallback to LLM-based simulation
TAVILY_API_KEY=

# RAG Knowledge Base Integration (optional) - for technical feasibility evaluation
# Path to the it-ops-rag project directory
RAG_DIR=

# Python executable of RAG project's venv (used when RAG_DIR is set)
RAG_PYTHON=

# Access password for the public demo (optional) - blocks API-cost abuse
# Leave empty for local dev (open). On deploy, set this (or a Streamlit secret
# of the same name) so only people you share it with can run the paid API.
APP_ACCESS_PASSWORD=
